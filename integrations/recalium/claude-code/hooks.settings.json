{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/integrations/recalium/hooks/recalium_session_start.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/integrations/recalium/hooks/recalium_stop.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
