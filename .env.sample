# Recalium Environment Variables
# Copy this file to .env and fill in real values.
# SECURITY: .env is gitignored. Never commit .env.
# SECURITY: API keys live ONLY here — never in the database. The DB stores
#           only a 4-character fingerprint and a boolean (key_configured).

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=recalium
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=recalium

# ── Application ─────────────────────────────────────────────────────────────
# APP_ENV: "production" or "development"
APP_ENV=development
# LOG_LEVEL: "debug", "info", "warning", "error"
LOG_LEVEL=info
# APP_PORT: host port that maps to container port 8000
APP_PORT=8000

# Network exposure (PRIV-06)
# Change from 127.0.0.1 to expose beyond localhost (requires APP_AUTH_BEARER)
APP_BIND_HOST=127.0.0.1
# Required when APP_BIND_HOST is non-localhost. Use a long random secret.
APP_AUTH_BEARER=

# ── Embedding backend ────────────────────────────────────────────────────────
# Controls whether sentence-transformers (local ML) is installed in the image.
# This is a BUILD-TIME setting — changing it requires `docker compose build`.
#   cpu   → sentence-transformers + CPU-only torch (~1.5 GB image delta)
#   gpu   → sentence-transformers + CUDA torch    (~4 GB image delta)
#   none  → no local ML; use OpenAI / Anthropic / Ollama for embeddings (default — smaller image)
EMBED_BACKEND=none

# ── BYOK Provider Keys (optional — system works without them) ────────────────
# OpenAI: https://platform.openai.com/api-keys
# Leave empty to operate in degraded mode (keyword search only, no embeddings via OpenAI).
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
# Leave empty to skip Anthropic-backed processing.
ANTHROPIC_API_KEY=

# Ollama: set URL if you run a local Ollama instance.
# Example: http://host.docker.internal:11434
OLLAMA_BASE_URL=
# Ollama API key (only needed if your Ollama deployment requires auth)
OLLAMA_API_KEY=

# ── Memory subsystem (memory/) ───────────────────────────────────────────────
# Authentication: the memory system uses GitHub Copilot's OpenAI-compatible API.
# On first run it performs an OAuth device flow to register credentials.
# No manual token setup is required — just run any memory script once.
# The credentials are cached at ~/.config/recalium-memory/credentials.json.

# Model overrides (optional — defaults are set in memory/scripts/config.py)
# MEMORY_FLUSH_MODEL=gpt-4o-mini
# MEMORY_COMPILE_MODEL=gpt-4o
# MEMORY_QUERY_MODEL=gpt-4o-mini
# MEMORY_LINT_MODEL=gpt-4o-mini

# Compile after this hour (24h UTC, default=18)
# MEMORY_COMPILE_AFTER_HOUR=18

# ── Evaluation Suite Configuration ──────────────────────────────────────────────
# Optional settings for evals/ framework (runner, metrics, reporting).
# Leave empty to use defaults.
EVAL_OUTPUT_DIR=evals/results
EVAL_BASE_URL=http://localhost:8000
