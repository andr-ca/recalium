# Recalium backend — local development environment
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Database (required)
DATABASE_URL=postgresql+asyncpg://recalium:recalium@localhost:5432/recalium

# Postgres connection parts (used if you run migrations or tools that need individual params)
POSTGRES_USER=recalium
POSTGRES_PASSWORD=recalium
POSTGRES_DB=recalium
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Application
APP_ENV=development
LOG_LEVEL=debug
APP_PORT=8000

# BYOK API keys (optional — leave empty if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2
