# Recalium backend — local development environment
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Database (required)
DATABASE_URL=postgresql+asyncpg://recalium:recalium@localhost:5432/recalium

# Postgres connection parts (used if you run migrations or tools that need individual params)
POSTGRES_USER=recalium
POSTGRES_PASSWORD=recalium
POSTGRES_DB=recalium
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Application
APP_ENV=development
LOG_LEVEL=debug
APP_PORT=8000

# Network exposure (PRIV-06)
# Change from 127.0.0.1 to expose beyond localhost (requires APP_AUTH_BEARER)
APP_BIND_HOST=127.0.0.1
# Required when APP_BIND_HOST is non-localhost. Use a long random secret.
APP_AUTH_BEARER=

# BYOK API keys (optional — leave empty if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2

# Per-function model + provider routing (F1/F2, BYOK-08).
# Models: "auto" = provider default (gpt-4o-mini / claude-3-haiku / OLLAMA_MODEL).
SUMMARIZE_MODEL=auto
EXTRACT_MODEL=auto
EMBED_MODEL=all-MiniLM-L6-v2
# Providers: auto | openai | anthropic | ollama ("auto" = first configured key).
SUMMARIZE_PROVIDER=auto
EXTRACT_PROVIDER=auto
EMBED_PROVIDER=sentence-transformers
